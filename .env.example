# .env.example — copiar a .env y ajustar valores

# Base de datos
DATABASE_URL=sqlite:///./punchclock.db

# Para PostgreSQL:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost/punchclock

# App
DEBUG=false
APP_TITLE=PunchClock API
APP_VERSION=2.0.0

# JWT — cambiar SECRET_KEY por un valor aleatorio seguro en producción
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-este-valor-en-produccion
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS — en producción reemplazar con el dominio real
# CORS_ORIGINS=["https://tu-dominio.com"]
